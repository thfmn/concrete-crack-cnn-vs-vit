# ============================================================
#  concrete-crack-cnn-vs-vit — Environment Configuration
# ============================================================
#  Copy this file to .env and adjust values for your machine.
#  .env is gitignored and will NOT be committed.
# ============================================================

# --- Data Paths ---
# Root directory containing sdnet2018/ and crackseg9k/ subdirectories
DATA_ROOT=assets

# --- MLflow ---
# Local directory for MLflow tracking data (runs, metrics, artifacts)
MLFLOW_TRACKING_URI=mlruns

# --- Training ---
# Comma-separated GPU IDs to use (e.g. "0" or "0,1"). Leave empty for CPU.
CUDA_VISIBLE_DEVICES=0

# --- Hydra ---
# Set to 1 for full stack traces on Hydra config errors (useful for debugging)
HYDRA_FULL_ERROR=1

# --- Reproducibility ---
# Global random seed for torch, numpy, and Lightning
SEED=42
